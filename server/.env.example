# ─── Database (Prisma Postgres — copy from Vercel Storage dashboard) ───────────
# Format: prisma+postgres://accelerate.prisma-data.net/?api_key=eyJ...
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_KEY_HERE"

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="replace-with-a-long-random-secret"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Email (Resend — https://resend.com) ───────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# Use onboarding@resend.dev for local testing, or replace with your verified Resend domain sender.
EMAIL_FROM="VolteX <onboarding@resend.dev>"

# ─── Admin seed account ────────────────────────────────────────────────────────
ADMIN_SEED_EMAIL="admin@voltex.com"
ADMIN_SEED_PASSWORD="changeme_strong_password_123!"
ADMIN_SEED_NAME="Admin"

# ─── CORS origins ──────────────────────────────────────────────────────────────
CLIENT_URL="http://localhost:3000"
ADMIN_URL="http://localhost:5173"

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV="development"
