generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  STAFF
  CUSTOMER
}

enum OtpPurpose {
  STAFF_LOGIN
  RESET_PASSWORD
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?  // Only ADMIN has this. STAFF logs in via OTP.
  phone        String?
  avatar       String?
  role         Role     @default(STAFF)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  invitationsSent Invitation[]   @relation("InvitedBy")
  refreshTokens   RefreshToken[]
  orders          Order[]
  cartItems       CartItem[]
  wishlistItems   WishlistItem[]
  addresses       Address[]
  reviews         Review[]

  @@index([email])
}

// ─── Invitations ─────────────────────────────────────────────────────────────

model Invitation {
  id          String   @id @default(cuid())
  email       String
  used        Boolean  @default(false)  // true once the staff member logs in
  invitedById String
  invitedBy   User     @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([email])                     // one active invitation per email
  @@index([email])
}

// ─── OTP Sessions ─────────────────────────────────────────────────────────────

model OtpSession {
  id        String     @id @default(cuid())
  email     String
  otpHash   String     // bcrypt hash of the 6-digit OTP
  purpose   OtpPurpose
  expiresAt DateTime   // 15 minutes from creation
  used      Boolean    @default(false)
  createdAt DateTime   @default(now())

  @@index([email, purpose])
}

// ─── Refresh Tokens ───────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique  // bcrypt hash of the actual token
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── Categories ───────────────────────────────────────────────────────────────

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  imageUrl  String?
  parentId  String?
  parent    Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategories")
  products  Product[]
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([slug])
  @@index([parentId])
}

// ─── Products ─────────────────────────────────────────────────────────────────

model Product {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  description       String?
  price             Decimal  @db.Decimal(10, 2)
  mrp               Decimal? @db.Decimal(10, 2)
  stock             Int      @default(0)
  images            String[] // Array of image URLs (Cloudinary / any CDN)
  brand             String?
  highlights        Json?
  specGroups        Json?
  overview          Json?
  variants          Json?
  bankOffers        Json?
  relatedProductIds String[] @default([])
  warranty          String?
  rating            Decimal? @db.Decimal(3, 2)
  ratingCount       Int      @default(0)
  reviewCount       Int      @default(0)
  deliveryDate      String?
  deliveryFee       String?
  isActive          Boolean  @default(true)
  categoryId        String
  category          Category @relation(fields: [categoryId], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  orderItems    OrderItem[]
  cartItems     CartItem[]
  wishlistItems WishlistItem[]
  reviews       Review[]

  @@index([slug])
  @@index([categoryId])
  @@index([brand])
}

// ─── Cart ─────────────────────────────────────────────────────────────────────

model CartItem {
  id        String  @id @default(cuid())
  quantity  Int     @default(1)
  userId    String
  productId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

// ─── Wishlist ────────────────────────────────────────────────────────────────

model WishlistItem {
  id        String  @id @default(cuid())
  userId    String
  productId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

// ─── Addresses ───────────────────────────────────────────────────────────────

model Address {
  id        String  @id @default(cuid())
  label     String  // e.g. "Home", "Work"
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  isDefault Boolean @default(false)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@index([userId])
}

// ─── Orders ──────────────────────────────────────────────────────────────────

model Order {
  id                String        @id @default(cuid())
  status            OrderStatus   @default(PENDING)
  paymentStatus     PaymentStatus @default(PENDING)
  paymentMethod     String        @default("COD")
  razorpayOrderId   String?
  razorpayPaymentId String?       @unique
  razorpaySignature String?
  totalAmount       Decimal       @db.Decimal(10, 2)
  couponCode        String?
  discountAmount    Decimal?      @db.Decimal(10, 2)
  userId            String
  addressId         String?
  user              User          @relation(fields: [userId], references: [id])
  address           Address?      @relation(fields: [addressId], references: [id])
  items             OrderItem[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([razorpayOrderId])
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Decimal @db.Decimal(10, 2) // price at time of purchase
  orderId   String
  productId String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

// ─── Coupons ─────────────────────────────────────────────────────────────────

model Coupon {
  id                String       @id @default(cuid())
  code              String       @unique
  discountType      DiscountType
  discountValue     Decimal      @db.Decimal(10, 2)
  minOrderAmount    Decimal?     @db.Decimal(10, 2)
  maxDiscountAmount Decimal?     @db.Decimal(10, 2)
  usageLimit        Int?
  usedCount         Int          @default(0)
  expiresAt         DateTime?
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([code])
}

// ─── Reviews ─────────────────────────────────────────────────────────────────

model Review {
  id         String   @id @default(cuid())
  rating     Int      // 1-5 stars
  title      String?
  comment    String
  isApproved Boolean  @default(false)
  userId     String
  productId  String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
}
